# EmailJS — contact form (https://www.emailjs.com/)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_USER_ID=

# Google reCAPTCHA v3 — site key, used by the contact form AND the quote form
# (https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_KEY=

# Google Analytics 4 — optional. Create a GA4 property at https://analytics.google.com
# and paste the Measurement ID (format G-XXXXXXXXXX). Leave blank to disable tracking.
# Link the GA4 property to Search Console in GA Admin for unified reporting.
VITE_GA_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Server-side (Netlify Functions) — used by netlify/functions/submit-quote.mts
# These are NOT prefixed with VITE_ so they never reach the browser bundle.
# ---------------------------------------------------------------------------

# reCAPTCHA v3 SECRET key (pairs with VITE_RECAPTCHA_KEY). If unset, the quote
# function skips verification in local dev only — production rejects all submissions.
RECAPTCHA_SECRET=

# Minimum reCAPTCHA v3 score (0–1). Default 0.7. Lower = more lenient, higher = stricter.
RECAPTCHA_MIN_SCORE=0.7

# --- Email delivery -------------------------------------------------------
# The function uses Resend if RESEND_API_KEY is set, otherwise Mailgun.
#
# Sender + destination (used by either provider):
# QUOTE_FROM_EMAIL  : sender, MUST be on your verified sending domain, e.g.
#                     "Gahitwen <quotes@mail.gahitwen.com>"
# QUOTE_TEAM_EMAIL  : where new quote tickets land (can be any inbox)
QUOTE_FROM_EMAIL=
QUOTE_TEAM_EMAIL=gahitwen@gmail.com

# Option A — Resend (https://resend.com). Generous free tier; preferred.
# Verify your domain in Resend, then set the key here.
RESEND_API_KEY=

# Option B — Mailgun (https://www.mailgun.com). Only used if RESEND_API_KEY is unset.
# MAILGUN_API_KEY : your Mailgun private API key
# MAILGUN_DOMAIN  : your sending domain, e.g. mail.gahitwen.com
# MAILGUN_REGION  : set to "eu" only if your Mailgun domain is EU-hosted
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=

# --- AI-drafted customer reply (optional) ---------------------------------
# Uses OpenRouter (https://openrouter.ai) to write the acknowledgement email.
# Tries each model in OPENROUTER_MODEL left-to-right until one succeeds, then
# falls back to a built-in template if all fail or the key is unset.
# OPENROUTER_MODEL: comma-separated list of models (leave blank for the default
# free-model chain: gpt-oss-120b → llama-3.3-70b → qwen3-next-80b → gemma-4-31b).
# Free model IDs change over time — verify at https://openrouter.ai/api/v1/models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Add an AI "suggested reply / next steps" block to the TEAM email (internal
# only; the raw ticket data is always included). Set to "false" to disable.
# Requires OPENROUTER_API_KEY. Defaults to enabled.
QUOTE_TEAM_AI_SUGGESTIONS=true

# Optional: forward every quote ticket to a help desk / automation as JSON.
# Works with Zapier, Make, HubSpot, Freshdesk, Chatwoot, osTicket, etc.
HELPDESK_WEBHOOK_URL=

# How pricing is presented to the CUSTOMER (the team email always keeps the
# full internal estimate regardless):
#   soft   (default) — one gentle "starts around X" ballpark, framed as guidance
#   exact            — the full indicative range (min – max)
#   none             — no pricing; a person follows up with a tailored quote
QUOTE_CUSTOMER_PRICING=soft

# Back-compat override: setting this to "false" forces QUOTE_CUSTOMER_PRICING=none
# (customer gets an acknowledgement only). Leave unset otherwise.
QUOTE_SEND_ESTIMATE_TO_CUSTOMER=
